# ── Large data files (never commit) ──────────────────────────────────────────
data/raw/
data/processed/
models/
logs/
results/figures/
results/tables/
.snakemake/
notebooks/
resources/

# ── Keep directory placeholders ───────────────────────────────────────────────
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/processed/paper_track/.gitkeep
!data/processed/alternative_track/.gitkeep
!data/metadata/.gitkeep
!models/.gitkeep
!logs/.gitkeep
!logs/paper_track/.gitkeep
!logs/alternative_track/.gitkeep
!results/figures/.gitkeep
!results/tables/.gitkeep
!results/tables/paper_track/.gitkeep
!results/tables/alternative_track/.gitkeep

# ── Metadata is small and manually curated — always track ────────────────────
!data/metadata/patient_metadata.tsv
!data/metadata/geo_metadata.tsv

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
